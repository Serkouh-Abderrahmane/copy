{"title":"Bóng Rổ","description":"","products":[{"product_id":"ao-thun-shoot-it-to-death","title":"Áo Thun Shoot It To Death","description":"\u003cp\u003eThông tin sản phẩm:\u003cbr\u003e- Dáng áo Relaxed Fit rộng rãi vừa đủ, tạo cảm giác thoải mái khi vận động, phù hợp cho cả nam và nữ.\u003cbr\u003e- Phần cổ áo được sử may bằng bo cổ chắc chắn, giúp giữ dáng lâu dài và hạn chế tình trạng giãn sau nhiều lần giặt.\u003cbr\u003e- Sử dụng công nghệ in kỹ thuật số cho hình ảnh sắc nét, bền màu.\u003cbr\u003eCác đường may được xử lý gọn gàng, chỉn chu đến từng chi tiết.\u003cbr\u003e- Bảng màu hiện đại, dễ dàng kết hợp với nhiều phong cách trang phục khác nhau.\u003cbr\u003e- Sản xuất tại Việt Nam.\u003c\/p\u003e","brand":"LUON VUITUOI","offers":[{"title":"Đen \/ XS","offer_id":52081303322944,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ S","offer_id":52081303355712,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ M","offer_id":52081303388480,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ L","offer_id":52081303421248,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ XL","offer_id":52081303454016,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ 2XL","offer_id":52081303486784,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ XS","offer_id":52081303519552,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ S","offer_id":52081303552320,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ M","offer_id":52081303585088,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ L","offer_id":52081303617856,"sku":"HT0231HT","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ XL","offer_id":5208130365