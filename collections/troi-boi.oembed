{"title":"Trơi Bời","description":"","products":[{"product_id":"ao-thun-if-you-see-da-police","title":"Áo Thun If You See Da Police","description":"\u003cp\u003eThông tin sản phẩm:\u003cbr\u003e- Dáng áo Relaxed Fit rộng rãi vừa đủ, tạo cảm giác thoải mái khi vận động, phù hợp cho cả nam và nữ.\u003cbr\u003e- Phần cổ áo được sử may bằng bo cổ chắc chắn, giúp giữ dáng lâu dài và hạn chế tình trạng giãn sau nhiều lần giặt.\u003cbr\u003e- Sử dụng công nghệ in kỹ thuật số cho hình ảnh sắc nét, bền màu.\u003cbr\u003eCác đường may được xử lý gọn gàng, chỉn chu đến từng chi tiết.\u003cbr\u003e- Bảng màu hiện đại, dễ dàng kết hợp với nhiều phong cách trang phục khác nhau.\u003cbr\u003e- Sản xuất tại Việt Nam.\u003c\/p\u003e","brand":"LUON VUITUOI","offers":[{"title":"Trắng \/ XS","offer_id":50792592343360,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ S","offer_id":50792592376128,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ M","offer_id":50792592408896,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ L","offer_id":50792592441664,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ XL","offer_id":50792592474432,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Trắng \/ 2XL","offer_id":50792592507200,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ XS","offer_id":50792592539968,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ S","offer_id":50792592572736,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ M","offer_id":50792592605504,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ L","offer_id":50792592638272,"sku":"MH1325MH","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ XL","offer_id":5