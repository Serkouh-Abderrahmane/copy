axed Fit rộng rãi vừa đủ, tạo cảm giác thoải mái khi vận động, phù hợp cho cả nam và nữ.\u003cbr\u003e- Phần cổ áo được sử may bằng bo cổ chắc chắn, giúp giữ dáng lâu dài và hạn chế tình trạng giãn sau nhiều lần giặt.\u003cbr\u003e- Sử dụng công nghệ in kỹ thuật số cho hình ảnh sắc nét, bền màu.\u003cbr\u003eCác đường may được xử lý gọn gàng, chỉn chu đến từng chi tiết.\u003cbr\u003e- Bảng màu hiện đại, dễ dàng kết hợp với nhiều phong cách trang phục khác nhau.\u003cbr\u003e- Sản xuất tại Việt Nam.\u003c\/p\u003e","brand":"LUON VUITUOI","offers":[{"title":"Ghi \/ XS","offer_id":52014936817984,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Ghi \/ S","offer_id":52014936850752,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Ghi \/ M","offer_id":52014936883520,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Ghi \/ L","offer_id":52014936916288,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Ghi \/ XL","offer_id":52014936949056,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Ghi \/ 2XL","offer_id":52014936981824,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ XS","offer_id":52014936621376,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ S","offer_id":52014936654144,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ M","offer_id":52014936686912,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ L","offer_id":52014936719680,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ XL","offer_id":52014936752448,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"Đen \/ 2XL","offer_id":52014936785216,"sku":"HN0063HN","price":165000.0,"currency_code":"VND","in_stock":true},{"title":"V